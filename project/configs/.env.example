# Шаблон переменных окружения. Скопируйте в корень проекта как .env:
#   cp configs/.env.example .env
# Реальный .env не коммитится (см. .gitignore).

LOG_LEVEL=INFO
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# Токен для защиты /predict. Если пусто — авторизация выключена.
# При заданном значении запрос должен содержать заголовок X-API-Token.
API_TOKEN=
